{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "avatar",
  "main": "./worker/index.ts",
  "compatibility_date": "2026-04-20",
  "observability": {
    "enabled": true
  },
  "assets": {
    "not_found_handling": "single-page-application",
    "run_worker_first": [
      "/avatar",
      "/avatar/"
    ]
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
